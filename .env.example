# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# OpenAI API key — used by the Vision API and ChatGPT parser.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Neon Postgres connection string — used by the SKU matcher and Vercel functions.
# Get one at https://neon.tech  (also works with any standard Postgres URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# Optional — AI providers
# ---------------------------------------------------------------------------

# Anthropic / Claude key (kept for the Flask app's optional Claude parser)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI model for Vision extraction (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Default AI provider used by the Flask upload route: "openai" or "claude"
# DEFAULT_AI_PROVIDER=openai

# ---------------------------------------------------------------------------
# Optional — Flask / matching
# ---------------------------------------------------------------------------

# Flask secret key — generate a random value for production
# SECRET_KEY=your-random-secret-here

# Upload folder (default: ./uploads) — set to /tmp for read-only filesystems
# UPLOAD_FOLDER=/tmp/uploads

# Hybrid matching weights for the Flask app (must sum to 1.0)
# FUZZY_WEIGHT=0.4
# VECTOR_WEIGHT=0.6

# Minimum confidence to flag a match as low-confidence in the review UI
# CONFIDENCE_THRESHOLD=0.45
