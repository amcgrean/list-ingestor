# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# OpenAI API key — used by the Vision API and ChatGPT parser.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Host port exposed by Docker Compose. Change to 8001 if another service
# already uses 8000 on the machine.
APP_PORT=8000

# Database URL can be left blank for Docker Compose deployments because the
# compose stack injects its own internal Postgres connection string.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Optional — AI providers
# ---------------------------------------------------------------------------

# Anthropic / Claude key (required when using the Claude parser)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI model for Vision extraction (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Default AI provider used by the Flask upload route: "openai" or "claude"
# DEFAULT_AI_PROVIDER=openai

# Cloudflare Access email header used for app identity
# CLOUDFLARE_ACCESS_EMAIL_HEADER=Cf-Access-Authenticated-User-Email

# Allow email-only local fallback sign-in for pre-created users
# ALLOW_LOCAL_LOGIN=true

# Comma-separated default branches to seed on startup
# DEFAULT_BRANCH_CODES=10FD,20GR,25BW,40CV

# Email to seed as the sole admin on startup
# BOOTSTRAP_ADMIN_EMAIL=amcgrean@beisserlumber.com

# ---------------------------------------------------------------------------
# Optional — Flask / matching
# ---------------------------------------------------------------------------

# Flask secret key — generate a random value for production
SECRET_KEY=your-random-secret-here

# Upload folder (default: ./uploads) — set to /tmp for read-only filesystems
# UPLOAD_FOLDER=/tmp/uploads

# Hybrid matching weights for the Flask app (must sum to 1.0)
# FUZZY_WEIGHT=0.4
# VECTOR_WEIGHT=0.6

# Minimum confidence to flag a match as low-confidence in the review UI
# CONFIDENCE_THRESHOLD=0.45
