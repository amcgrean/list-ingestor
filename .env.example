# Copy this file to .env and fill in your values
# Never commit .env to source control

# Required: Claude API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the default SQLite path for PostgreSQL in production
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Change the model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: Flask secret key (generate a random one for production)
# SECRET_KEY=your-random-secret-here

# Optional: Upload folder (default: ./uploads)
# UPLOAD_FOLDER=/tmp/uploads

# Optional: Matching weights (must sum to 1.0)
# FUZZY_WEIGHT=0.4
# VECTOR_WEIGHT=0.6

# Optional: Minimum confidence score to flag a match as low-confidence
# CONFIDENCE_THRESHOLD=0.45
